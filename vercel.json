{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' https://images.unsplash.com https://grainy-gradients.vercel.app https://www.google-analytics.com data:; connect-src 'self' https://formspree.io https://www.google-analytics.com https://analytics.google.com https://stats.g.doubleclick.net" }
      ]
    }
  ],
  "redirects": [
    { "source": "/fsa", "destination": "/fsa-guide", "permanent": true },
    { "source": "/rdap", "destination": "/rdap-guide", "permanent": true },
    { "source": "/blog/rdap-explicado", "destination": "/blog", "permanent": true },
    { "source": "/blog/first-step-act-creditos-etc", "destination": "/blog", "permanent": true },
    { "source": "/blog/reducir-sentencia-federal-2026", "destination": "/blog", "permanent": true },
    { "source": "/blog/saltar-halfway-house-2026", "destination": "/blog", "permanent": true }
  ]
}
